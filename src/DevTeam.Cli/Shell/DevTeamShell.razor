@namespace DevTeam.Cli.Shell

<Rows>
    @foreach (var msg in _visibleMessages)
    {
        if (msg.Kind == ShellMessageKind.Panel)
        {
            <Panel Title="@msg.Title" BorderColor="@msg.BorderColor" TitleColor="@msg.TitleColor">
                <RawMarkup Content="@msg.Markup" />
            </Panel>
        }
        else
        {
            <RawMarkup Content="@msg.Markup" />
        }
    }
    <TextInput @bind-Value="_input"
               Placeholder="@Shell.PromptText"
               OnSubmit="HandleSubmitAsync"
               Expand="true"
               FocusedBorderColor="Color.Cyan" />
</Rows>
