@namespace DevTeam.Cli.Shell
@inject ShellService Shell
@implements IDisposable

<Rows>
    @foreach (var msg in Shell.Messages)
    {
        if (msg.Kind == ShellMessageKind.Panel)
        {
            <Panel Title="@msg.Title" BorderColor="@msg.BorderColor" TitleColor="@msg.TitleColor">
                <RawMarkup Content="@msg.Markup" />
            </Panel>
        }
        else
        {
            <RawMarkup Content="@msg.Markup" />
        }
    }
    <TextInput @bind-Value="_input"
               Placeholder="@Shell.PromptText"
               OnSubmit="HandleSubmitAsync"
               Expand="true"
               FocusedBorderColor="Color.Cyan" />
</Rows>

@code {
    private string? _input;

    protected override void OnInitialized()
    {
        Shell.OnStateChanged += Refresh;
        _ = Shell.InitializeAsync();
    }

    private void Refresh() => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmitAsync(string? line)
    {
        _input = null;
        if (!string.IsNullOrWhiteSpace(line))
            await Shell.ProcessInputAsync(line.Trim());
    }

    public void Dispose() => Shell.OnStateChanged -= Refresh;
}
